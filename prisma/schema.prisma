// GeoHub TR — Türkiye Jeodezi & Haritacılık Hizmetleri Platformu
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  COMPANY_OWNER
  INDIVIDUAL

  @@map("user_role")
}

// Üyelik Seviyeleri: Ücretsiz / Onaylı (500 TL/ay) / Premium (1500 TL/ay)
enum SubscriptionTier {
  FREE      // Ücretsiz — temel liste
  ONAYLI    // Onaylı Üye — 500 TL/ay, rozet, analytics
  PREMIUM   // Premium Üye — 1500 TL/ay, WhatsApp bildirimi, öncelikli liste

  @@map("subscription_tier")
}

enum ServiceCategory {
  // ─── Klasik Jeodezi & Kadastro ──────────────────────────────
  ROLOVE                  // Rölöve (mimari, yapısal, as-built)
  ESKI_ESER               // Eski Eser Rölövesi & Restorasyon
  HALIHAZIR_HARITA        // Halihazır Harita (1/500 → 1/25000)
  APLIKASYON              // Aplikasyon, İfraz, Tevhit
  LIHKAB                  // LİHKAB — Lisanslı Harita Kadastro Büroları
  INSAAT_KONTROL          // İnşaat Kontrol & Metraj
  MADEN_OCAK              // Maden & Ocak Ölçümü

  // ─── 3D Teknoloji ───────────────────────────────────────────
  LAZER_TARAMA            // Lazer Tarama & 3D Nokta Bulutu
  BIM_MODELLEME           // BIM Modelleme (Revit, IFC, Dijital İkiz)
  FOTOGRAMETRI            // Fotogrametri (SfM, yersel, hava)
  DRONE_HARITALAMA        // Drone / İHA Haritalama

  // ─── CBS / GIS ──────────────────────────────────────────────
  CBS_GIS                 // CBS / GIS Hizmetleri

  // ─── Ticari & Değerleme ─────────────────────────────────────
  GAYRIMENKUL_DEGERLEME   // Gayrimenkul Değerleme (SPK lisanslı)

  // ─── Ekipman ────────────────────────────────────────────────
  CIHAZ_SATIS             // Cihaz Satış & Kiralama (kurumsal + bireysel)

  // ─── Eğitim Kurumları ───────────────────────────────────────
  EGITIM_KURUMU           // Üniversite, MYO, lise, kurs merkezi

  @@map("service_category")
}

enum ListingType {
  SERVICE   // Hizmet tanımı
  RENTAL    // Cihaz kiralama
  SALE      // Cihaz satışı

  @@map("listing_type")
}

enum ListingStatus {
  ACTIVE
  DRAFT
  ARCHIVED

  @@map("listing_status")
}

enum ServiceRequestStatus {
  OPEN        // Teklife açık
  IN_PROGRESS // Teklif alındı, değerlendiriliyor
  AWARDED     // Firma seçildi
  CLOSED      // Kapatıldı

  @@map("service_request_status")
}

enum BidStatus {
  PENDING   // Teklif gönderildi
  ACCEPTED  // Kabul edildi
  REJECTED  // Reddedildi

  @@map("bid_status")
}

enum KnowledgeBaseType {
  BLOG          // Blog yazısı
  COMPARISON    // Cihaz karşılaştırma
  TECHNICAL_DOC // Teknik belge
  NEWS          // Sektör haberi

  @@map("knowledge_base_type")
}

enum KnowledgeBaseStatus {
  DRAFT
  PUBLISHED

  @@map("knowledge_base_status")
}

enum ClaimRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("claim_request_status")
}

// ─── İş İlanı Enums ───────────────────────────────────────────────────────────

enum JobType {
  FULL_TIME    // Tam zamanlı
  PART_TIME    // Yarı zamanlı
  FREELANCE    // Serbest / Proje bazlı
  INTERNSHIP   // Staj

  @@map("job_type")
}

enum JobWorkModel {
  ON_SITE  // Ofis / Saha
  REMOTE   // Uzaktan
  HYBRID   // Hibrit

  @@map("job_work_model")
}

enum JobStatus {
  OPEN    // İlan aktif
  PAUSED  // Durduruldu
  CLOSED  // Kapatıldı

  @@map("job_status")
}

enum ApplicationStatus {
  PENDING      // Başvuru alındı
  REVIEWED     // İncelendi
  SHORTLISTED  // Ön elemeyi geçti
  REJECTED     // Reddedildi
  HIRED        // İşe alındı

  @@map("application_status")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  image          String?
  emailVerified  DateTime? @map("email_verified")
  hashedPassword String?   @map("hashed_password")
  role           UserRole  @default(INDIVIDUAL)
  // Telefon — sadece ofis/genel iletişim için kullanılır
  phone          String?
  city           String?   // 81 ilden biri
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // CV / Bireysel profil alanları
  cvUrl          String?   @map("cv_url")          // PDF CV linki
  linkedinUrl    String?   @map("linkedin_url")
  skills         Json      @default("[]")           // ["AutoCAD", "Civil3D", "ArcGIS"]
  experienceYears Int?     @map("experience_years") // 0=stajyer, 1-3=jr, 4-8=mid, 9+=sr

  // Relations
  accounts           Account[]
  sessions           Session[]
  companies          Company[]        @relation("CompanyOwner")
  claimRequests      ClaimRequest[]   @relation("UserClaimRequests")
  reviewedClaims     ClaimRequest[]   @relation("ClaimReviewer")
  knowledgeBaseItems KnowledgeBase[]
  serviceRequests    ServiceRequest[] @relation("RequestOwner")
  bids               Bid[]            @relation("CompanyBids")
  jobApplications    JobApplication[] @relation("ApplicantApplications")

  @@map("users")
}

model Company {
  id               String           @id @default(uuid())
  ownerId          String?          @map("owner_id")
  name             String
  slug             String           @unique
  logoUrl          String?          @map("logo_url")
  website          String?

  // Açıklama ve iletişim
  description      String?          @db.Text
  // Sadece ofis/genel telefon (kişisel gizli)
  officePhone      String?          @map("office_phone")
  // Sadece info@ / genel eposta (kişisel gizli)
  infoEmail        String?          @map("info_email")
  // WhatsApp — sadece PREMIUM firma sahipleri görebilir / bildirim alır
  whatsappNumber   String?          @map("whatsapp_number")

  // Konum
  address          String?
  city             String?           // Örn: "İstanbul", "Ankara"
  district         String?           // İlçe

  // Durum
  isClaimed        Boolean          @default(false) @map("is_claimed")
  isVerified       Boolean          @default(false) @map("is_verified")
  subscriptionTier SubscriptionTier @default(FREE)  @map("subscription_tier")
  promotedUntil    DateTime?        @map("promoted_until")

  // Hizmet kategorileri (JSON dizi: ["ROLOVE", "LAZER_TARAMA"])
  serviceCategories Json            @default("[]") @map("service_categories")

  // İstatistikler
  viewCount        Int              @default(0) @map("view_count")
  contactClickCount Int             @default(0) @map("contact_click_count")

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  owner              User?            @relation("CompanyOwner", fields: [ownerId], references: [id])
  listings           Listing[]
  claimRequests      ClaimRequest[]
  bids               Bid[]            @relation("CompanyBidList")
  sponsoredArticles  KnowledgeBase[]  @relation("SponsoredArticles")
  jobListings        JobListing[]     @relation("CompanyJobs")

  @@map("companies")
}

// Hizmet listesi (EuroPages tarzı — fiyat opsiyonel)
model Listing {
  id                String        @id @default(uuid())
  companyId         String        @map("company_id")
  serviceCategory   ServiceCategory @map("service_category")
  // Alt kategori slug — src/lib/service-categories.ts'den geçerli bir değer
  subCategory       String?       @map("sub_category")
  listingType       ListingType   @map("listing_type")
  title             String
  description       String        @db.Text
  // Fiyat opsiyonel — firma belirtmek zorunda değil
  price             Decimal?      @db.Decimal(12, 2)
  currency          String        @default("TRY")
  // Ek özellikler JSONB (bölge, cihaz markası, vs.)
  dynamicAttributes Json          @default("{}") @map("dynamic_attributes")
  images            Json          @default("[]")
  isPromoted        Boolean       @default(false) @map("is_promoted")
  status            ListingStatus @default(DRAFT)
  viewCount         Int           @default(0) @map("view_count")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("listings")
}

// ─── Talep / İhale Sistemi ────────────────────────────────────────────────────

// Kullanıcı ya da firma tarafından açılan hizmet talebi
model ServiceRequest {
  id              String               @id @default(uuid())
  requesterId     String               @map("requester_id")
  serviceCategory ServiceCategory      @map("service_category")
  // Alt kategori slug — src/lib/service-categories.ts'den geçerli bir değer
  subCategory     String?              @map("sub_category")
  title           String
  description     String               @db.Text

  // Konum bilgisi
  city            String               // Hangi ilde yapılacak
  district        String?              // İlçe (opsiyonel)

  // Bütçe (opsiyonel, üst limit)
  budgetMax       Decimal?             @db.Decimal(12, 2) @map("budget_max")
  currency        String               @default("TRY")

  // Detaylar JSONB (alan büyüklüğü, dosya formatı, vb.)
  details         Json                 @default("{}") @map("details")

  status          ServiceRequestStatus @default(OPEN)
  deadline        DateTime?            // İşin tamamlanma tarihi

  // Kaç firma görüntüledi / teklif verdi
  viewCount       Int                  @default(0) @map("view_count")
  bidCount        Int                  @default(0) @map("bid_count")

  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  requester User  @relation("RequestOwner", fields: [requesterId], references: [id])
  bids      Bid[]

  @@map("service_requests")
}

// Firma tarafından gönderilen teklif
model Bid {
  id               String    @id @default(uuid())
  serviceRequestId String    @map("service_request_id")
  companyId        String    @map("company_id")
  bidderId         String    @map("bidder_id") // Firma sahibi User ID

  // Teklif fiyatı (opsiyonel — firma sadece "ilgileniyorum" diyebilir)
  price            Decimal?  @db.Decimal(12, 2)
  currency         String    @default("TRY")
  message          String    @db.Text
  estimatedDays    Int?      @map("estimated_days") // Tahmini iş süresi (gün)

  status           BidStatus @default(PENDING)

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  company        Company        @relation("CompanyBidList", fields: [companyId], references: [id])
  bidder         User           @relation("CompanyBids", fields: [bidderId], references: [id])

  @@unique([serviceRequestId, companyId]) // Her firma bir talebe bir kez teklif verebilir
  @@map("bids")
}

// ─── Bilgi Merkezi ─────────────────────────────────────────────────────────────

model KnowledgeBase {
  id          String              @id @default(uuid())
  authorId    String              @map("author_id")
  type        KnowledgeBaseType   @default(BLOG)
  title       String
  slug        String              @unique
  content     String              @db.Text
  excerpt     String?             @db.Text
  coverImage  String?             @map("cover_image")
  tags        Json                @default("[]")
  // Sponsorlu içerik (ücretli tanıtım — açıkça belirtilir)
  isSponsored Boolean             @default(false) @map("is_sponsored")
  sponsorId   String?             @map("sponsor_id")
  status      KnowledgeBaseStatus @default(DRAFT)
  readCount   Int                 @default(0) @map("read_count")
  publishedAt DateTime?           @map("published_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  author  User     @relation(fields: [authorId], references: [id])
  sponsor Company? @relation("SponsoredArticles", fields: [sponsorId], references: [id])

  @@map("knowledge_base")
}

// ─── Profil Sahiplenme ─────────────────────────────────────────────────────────

model ClaimRequest {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  companyId   String             @map("company_id")
  status      ClaimRequestStatus @default(PENDING)
  message     String?            @db.Text
  reviewedAt  DateTime?          @map("reviewed_at")
  reviewedBy  String?            @map("reviewed_by")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  user     User     @relation("UserClaimRequests", fields: [userId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  reviewer User?    @relation("ClaimReviewer", fields: [reviewedBy], references: [id])

  @@map("claim_requests")
}

// ─── İş İlanları ───────────────────────────────────────────────────────────────

// Kurumsal firma tarafından açılan iş ilanı
// - Sadece ONAYLI veya PREMIUM firmalar ilan açabilir (middleware ile kontrol)
// - FREE firma: ilan paneli görür ama "Üyeliğinizi Yükseltin" uyarısı alır
model JobListing {
  id               String        @id @default(uuid())
  companyId        String        @map("company_id")

  // İlan başlığı ve içerik
  title            String        // "Kıdemli Harita Mühendisi"
  description      String        @db.Text
  requirements     String?       @db.Text   // Aranan nitelikler (JSONB alternatif)
  responsibilities String?       @db.Text   // Görev tanımı

  // Pozisyon detayları
  serviceCategory  ServiceCategory? @map("service_category") // Hangi uzmanlık alanı
  jobType          JobType       @map("job_type")            // Tam/yarı/freelance/staj
  workModel        JobWorkModel  @map("work_model")          // Ofis/Remote/Hibrit

  // Konum
  city             String        // İlan şehri
  district         String?       // İlçe (opsiyonel)

  // Maaş (opsiyonel — firma göstermek zorunda değil)
  salaryMin        Decimal?      @db.Decimal(12, 2) @map("salary_min")
  salaryMax        Decimal?      @db.Decimal(12, 2) @map("salary_max")
  currency         String        @default("TRY")

  // Gereksinimler (yapılandırılmış)
  experienceYears  Int?          @map("experience_years") // Minimum yıl
  requiredSkills   Json          @default("[]") @map("required_skills") // ["AutoCAD","Revit"]
  preferredSkills  Json          @default("[]") @map("preferred_skills")

  // Durum & istatistik
  status           JobStatus     @default(OPEN)
  applicationCount Int           @default(0) @map("application_count")
  viewCount        Int           @default(0) @map("view_count")
  deadline         DateTime?     // Başvuru son tarihi
  publishedAt      DateTime?     @map("published_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  company      Company          @relation("CompanyJobs", fields: [companyId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@map("job_listings")
}

// Bireysel kullanıcı tarafından gönderilen başvuru
// - Sadece INDIVIDUAL rolündeki kullanıcılar başvurabilir (firma sahibi başvuramaz)
// - Kullanıcı başvuru mektubunu + CV linkini ileter
model JobApplication {
  id           String            @id @default(uuid())
  jobListingId String            @map("job_listing_id")
  applicantId  String            @map("applicant_id")

  // Başvuru içeriği
  coverLetter  String?           @db.Text @map("cover_letter")
  cvUrl        String?           @map("cv_url")        // Kullanıcı profilindekini geçersiz kılar

  // Ek dosyalar (portfolio, sertifikalar)
  attachments  Json              @default("[]")

  // İşlem
  status       ApplicationStatus @default(PENDING)
  // Firma notları — başvurucuya görünmez
  internalNote String?           @db.Text @map("internal_note")
  reviewedAt   DateTime?         @map("reviewed_at")

  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  jobListing JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  applicant  User       @relation("ApplicantApplications", fields: [applicantId], references: [id])

  @@unique([jobListingId, applicantId]) // Aynı ilana bir kez başvurulabilir
  @@map("job_applications")
}
