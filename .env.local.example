# ─────────────────────────────────────────────────────────────────────────────
# GeoHub TR — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun:
#   cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API bölümünden alın

# Project URL (örn: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon/Public Key — tarayıcıda güvenli kullanılabilir
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — SADECE sunucu tarafında, hiçbir zaman tarayıcıya göndermeyin!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── VERİTABANI (Prisma — Supabase PostgreSQL kullanıyorsanız) ────────────────
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Transaction Pooler (port 6543) veya Session Pooler (port 5432)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection (Prisma migration için)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET=your-very-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ─── GOOGLE MAPS (opsiyonel — OpenStreetMap ücretsiz kullanılabilir) ──────────
# Harita görünümünü Google Maps'e geçirmek için:
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── AWS S3 (logo & medya yüklemeleri için — opsiyonel) ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_BUCKET_NAME=geohub-media

# ─── UYGULAMA ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
